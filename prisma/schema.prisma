generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum ClubStatus { ACTIVE ARCHIVED }
enum SubscriberStatus { ACTIVE PAUSED ARCHIVED }
enum SubscriptionStatus { ACTIVE PAUSED CANCELLED ENDED }
enum MailRunStatus { DRAFT GENERATED LOCKED COMPLETED CANCELLED }
enum MailRunItemStatus { PENDING PACKED SHIPPED SKIPPED }
enum AddressValidationStatus { UNVALIDATED VALID INVALID NEEDS_REVIEW }
enum PlatformSubscriptionStatus { ACTIVE TRIALING PAST_DUE CANCELLED }
enum ClubItemType { STICKER PRINT ACEO ORIGINAL_ART POSTCARD BOOKMARK OTHER }

model User { id String @id @default(cuid()) email String @unique name String? artistAccounts ArtistAccount[] auditLogs AuditLog[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@map("users") }
model ArtistAccount { id String @id @default(cuid()) userId String @map("user_id") displayName String @map("display_name") publicSlug String @unique @map("public_slug") bio String? user User @relation(fields:[userId],references:[id],onDelete:Cascade) clubs Club[] platformSubscriptions PlatformSubscription[] auditLogs AuditLog[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([userId]) @@map("artist_accounts") }
model PlatformPlan { id String @id @default(cuid()) name String slug String @unique monthlyPriceCents Int @map("monthly_price_cents") annualPriceCents Int? @map("annual_price_cents") isPublic Boolean @default(false) @map("is_public") isActive Boolean @default(true) @map("is_active") subscriptions PlatformSubscription[] @@map("platform_plans") }
model PlatformSubscription { id String @id @default(cuid()) artistAccountId String @map("artist_account_id") platformPlanId String @map("platform_plan_id") status PlatformSubscriptionStatus @default(TRIALING) startedAt DateTime @default(now()) @map("started_at") cancelledAt DateTime? @map("cancelled_at") artistAccount ArtistAccount @relation(fields:[artistAccountId],references:[id],onDelete:Cascade) platformPlan PlatformPlan @relation(fields:[platformPlanId],references:[id]) @@index([artistAccountId,status]) @@map("platform_subscriptions") }
model Club { id String @id @default(cuid()) artistAccountId String @map("artist_account_id") name String description String? status ClubStatus @default(ACTIVE) artistAccount ArtistAccount @relation(fields:[artistAccountId],references:[id],onDelete:Cascade) plans ClubPlan[] items ClubItem[] subscribers Subscriber[] mailRuns MailRun[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([artistAccountId,status]) @@map("clubs") }
model ClubPlan { id String @id @default(cuid()) clubId String @map("club_id") name String description String? priceCents Int @default(0) @map("price_cents") isActive Boolean @default(true) @map("is_active") sortOrder Int @default(0) @map("sort_order") club Club @relation(fields:[clubId],references:[id],onDelete:Cascade) planItems ClubPlanItem[] subscriptions Subscription[] mailRunItems MailRunItem[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([clubId,isActive]) @@map("club_plans") }
model ClubItem { id String @id @default(cuid()) clubId String @map("club_id") name String itemType ClubItemType @default(OTHER) @map("item_type") isActive Boolean @default(true) @map("is_active") club Club @relation(fields:[clubId],references:[id],onDelete:Cascade) planItems ClubPlanItem[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([clubId,isActive]) @@map("club_items") }
model ClubPlanItem { id String @id @default(cuid()) clubPlanId String @map("club_plan_id") clubItemId String @map("club_item_id") quantity Int @default(1) clubPlan ClubPlan @relation(fields:[clubPlanId],references:[id],onDelete:Cascade) clubItem ClubItem @relation(fields:[clubItemId],references:[id],onDelete:Cascade) @@unique([clubPlanId,clubItemId]) @@map("club_plan_items") }
model Subscriber { id String @id @default(cuid()) clubId String @map("club_id") email String firstName String @map("first_name") lastName String @map("last_name") status SubscriberStatus @default(ACTIVE) joinedAt DateTime @default(now()) @map("joined_at") archivedAt DateTime? @map("archived_at") club Club @relation(fields:[clubId],references:[id],onDelete:Cascade) subscriptions Subscription[] addresses SubscriberAddress[] addressTokens SubscriberAddressToken[] mailRunItems MailRunItem[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([clubId,status]) @@unique([clubId,email]) @@map("subscribers") }
model Subscription { id String @id @default(cuid()) subscriberId String @map("subscriber_id") clubPlanId String @map("club_plan_id") status SubscriptionStatus @default(ACTIVE) startedAt DateTime @default(now()) @map("started_at") endedAt DateTime? @map("ended_at") subscriber Subscriber @relation(fields:[subscriberId],references:[id],onDelete:Cascade) clubPlan ClubPlan @relation(fields:[clubPlanId],references:[id]) mailRunItems MailRunItem[] @@index([subscriberId,status]) @@index([clubPlanId,status]) @@map("subscriptions") }
model SubscriberAddress { id String @id @default(cuid()) subscriberId String @map("subscriber_id") encryptedPayload Json @map("encrypted_payload") validationStatus AddressValidationStatus @default(UNVALIDATED) @map("validation_status") validatedAt DateTime? @map("validated_at") subscriber Subscriber @relation(fields:[subscriberId],references:[id],onDelete:Cascade) createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([subscriberId]) @@map("subscriber_addresses") }
model SubscriberAddressToken { id String @id @default(cuid()) subscriberId String @map("subscriber_id") tokenHash String @unique @map("token_hash") expiresAt DateTime? @map("expires_at") usedAt DateTime? @map("used_at") subscriber Subscriber @relation(fields:[subscriberId],references:[id],onDelete:Cascade) createdAt DateTime @default(now()) @map("created_at") @@index([subscriberId]) @@map("subscriber_address_tokens") }
model MailRun { id String @id @default(cuid()) clubId String @map("club_id") name String month String status MailRunStatus @default(DRAFT) generatedAt DateTime? @map("generated_at") lockedAt DateTime? @map("locked_at") requiredItemCounts Json? @map("required_item_counts") club Club @relation(fields:[clubId],references:[id],onDelete:Cascade) items MailRunItem[] createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") @@index([clubId,status]) @@map("mail_runs") }
model MailRunItem { id String @id @default(cuid()) mailRunId String @map("mail_run_id") subscriberId String @map("subscriber_id") subscriptionId String @map("subscription_id") clubPlanId String @map("club_plan_id") status MailRunItemStatus @default(PENDING) packedAt DateTime? @map("packed_at") shippedAt DateTime? @map("shipped_at") planSnapshot Json @map("plan_snapshot") addressSnapshot Json? @map("address_snapshot") mailRun MailRun @relation(fields:[mailRunId],references:[id],onDelete:Cascade) subscriber Subscriber @relation(fields:[subscriberId],references:[id]) subscription Subscription @relation(fields:[subscriptionId],references:[id]) clubPlan ClubPlan @relation(fields:[clubPlanId],references:[id]) @@index([mailRunId,status]) @@map("mail_run_items") }
model AuditLog { id String @id @default(cuid()) actorUserId String? @map("actor_user_id") artistAccountId String @map("artist_account_id") action String objectType String @map("object_type") objectId String @map("object_id") metadata Json? actorUser User? @relation(fields:[actorUserId],references:[id]) artistAccount ArtistAccount @relation(fields:[artistAccountId],references:[id],onDelete:Cascade) createdAt DateTime @default(now()) @map("created_at") @@index([artistAccountId,action]) @@map("audit_logs") }
